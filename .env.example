# Chamaroma Studio — Environment Variables
# Copie este arquivo para .env e preencha com seus valores

# Google Gemini API Key (obrigatorio)
GEMINI_API_KEY=sua-chave-aqui

# CORS origins (separado por virgula, sem espacos)
# Apos deploy no Vercel, troque pela URL real (ex: https://chamaroma-anapaula.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173,https://chamaroma-anapaula.vercel.app
